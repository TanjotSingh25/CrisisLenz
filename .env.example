# Copy to .env and fill in GEMINI_API_KEY.

# --- Database ---
DATABASE_URL=postgresql://crisislens:crisislens@db:5432/crisislens
POSTGRES_USER=crisislens
POSTGRES_PASSWORD=crisislens
POSTGRES_DB=crisislens

# --- Gemini (Module 3 analysis) ---
GEMINI_API_KEY=your_key_here

# Primary model, tried first on every request.
GEMINI_MODEL=gemini-2.5-flash

# Comma-separated fallback models, tried in order ONLY when the primary is
# rate-limited (429). Each model has its own free-tier quota bucket, so this
# lets analysis keep working after one model's per-minute limit is hit.
GEMINI_FALLBACK_MODELS=gemini-2.5-flash-lite,gemini-2.0-flash,gemini-2.0-flash-lite

# --- Frontend (optional) ---
# VITE_API_BASE_URL=http://localhost:8000
