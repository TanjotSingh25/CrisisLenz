# Copy to .env and fill in GEMINI_API_KEY.

# --- Database ---
DATABASE_URL=postgresql://crisislens:crisislens@db:5432/crisislens
POSTGRES_USER=crisislens
POSTGRES_PASSWORD=crisislens
POSTGRES_DB=crisislens

# --- Gemini (Module 3 analysis) ---
GEMINI_API_KEY=your_key_here

# Primary model, tried first on every request.
GEMINI_MODEL=gemini-2.5-flash

# Comma-separated fallback models, tried in order ONLY when the primary is
# rate-limited (429). Each model has its own free-tier quota bucket, so this
# lets analysis keep working after one model's per-minute limit is hit.
GEMINI_FALLBACK_MODELS=gemini-2.5-flash-lite,gemini-2.0-flash,gemini-2.0-flash-lite

# --- Deployment / security ---
# "development" (default) or "production". In production, error responses are
# generic (no internals leaked) and missing secrets fail startup.
ENVIRONMENT=development

# Comma-separated browser origins allowed to call the API (no wildcard).
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional. If set, all mutation endpoints (POST/PUT/PATCH/DELETE) require the
# header  X-Demo-Admin-Token: <this value>. Leave empty for open local demos.
# NEVER put this in the frontend — it would leak into the browser bundle.
DEMO_ADMIN_TOKEN=

# --- Frontend (optional) ---
# The ONLY variable the frontend should ever receive. No secrets here.
# VITE_API_BASE_URL=http://localhost:8000
